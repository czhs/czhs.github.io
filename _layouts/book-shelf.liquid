---
layout: page
---
{{ content }}

<style>
.shelf-divider {
  margin: 2.5rem 0 1.75rem;
  border: 0;
  border-top: 1px solid var(--global-divider-color);
}
.shelf-recs-note {
  margin-top: 2.5rem;
  text-align: center;
  font-style: italic;
  color: var(--global-text-color-light);
  font-size: 0.95rem;
}
</style>

{% if page.collection and page.collection.size > 0 %}
  {% assign collection = site[page.collection] %}
  {% if collection and collection.size > 0 %}
    {% comment %}
      Two sections only:
        1. The "discuss" shelf — books explicitly tagged for conversation.
        2. Everything else, randomized into a single shelf each visit.
      All other prior groupings (recommended / art / per-year) have been
      collapsed; only year is kept on the per-book pages.
    {% endcomment %}

    {% assign discuss_books = '' | split: '' %}
    {% assign other_books = '' | split: '' %}
    {% for item in collection %}
      {% assign is_discuss = false %}
      {% if item.shelf_tags contains 'discuss' or item.shelf_tags contains 'discussion' or item.discuss == true or item.talk == true %}
        {% assign is_discuss = true %}
      {% endif %}
      {% if is_discuss %}
        {% assign discuss_books = discuss_books | push: item %}
      {% else %}
        {% assign other_books = other_books | push: item %}
      {% endif %}
    {% endfor %}

    {% if discuss_books and discuss_books.size > 0 %}
      <h2 id="discuss">Have you read these? I would love to talk to you about them!</h2>
      <div class="book-shelf-grid">
        {% for item in discuss_books reversed %}
          <figure class="cover">
            <a class="cover-link" href="{{ item.url | relative_url }}">
              {% if item.cover %}
                <img alt="{{ item.title }} cover" src="{{ item.cover | prepend: page.covers | relative_url }}" style="height:200px">
              {% elsif item.olid %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/olid/{{ item.olid }}-L.jpg?default=false" style="height:200px">
              {% elsif item.isbn %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/isbn/{{ item.isbn }}-L.jpg?default=false" style="height:200px">
              {% endif %}
            </a>
          </figure>
        {% endfor %}
      </div>
    {% endif %}

    {% if other_books and other_books.size > 0 %}
      {% if discuss_books and discuss_books.size > 0 %}<hr class="shelf-divider">{% endif %}
      <h2 id="shelf">my books, in randomized order</h2>
      {% assign shuffled = other_books | sample: other_books.size %}
      <div class="book-shelf-grid" id="book-shelf-grid">
        {% for item in shuffled %}
          <figure class="cover">
            <a class="cover-link" href="{{ item.url | relative_url }}">
              {% if item.cover %}
                <img alt="{{ item.title }} cover" src="{{ item.cover | prepend: page.covers | relative_url }}" style="height:200px">
              {% elsif item.olid %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/olid/{{ item.olid }}-L.jpg?default=false" style="height:200px">
              {% elsif item.isbn %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/isbn/{{ item.isbn }}-L.jpg?default=false" style="height:200px">
              {% endif %}
            </a>
          </figure>
        {% endfor %}
      </div>
      <script>
        // Reshuffle on each page load so the shelf feels alive between visits.
        // (Liquid already gave us one random ordering at build time; this layers
        // a client-side shuffle on top so visitors see a fresh layout each time.)
        (() => {
          const grid = document.getElementById('book-shelf-grid');
          if (!grid) return;
          const items = Array.from(grid.children);
          for (let i = items.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [items[i], items[j]] = [items[j], items[i]];
          }
          const frag = document.createDocumentFragment();
          items.forEach(el => frag.appendChild(el));
          grid.appendChild(frag);
        })();
      </script>
    {% endif %}

    <p class="shelf-recs-note">book recomendations? please feel free to reach out to me!</p>
  {% endif %}
{% endif %}
