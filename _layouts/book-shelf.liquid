---
layout: page
---
{{ content }}

{% if page.collection and page.collection.size > 0 %}
  {% assign collection = site[page.collection] %}
  {% if collection and collection.size > 0 %}
    {% comment %}
      Optional "shelf tags" for books.

      Add to any book in `_books/*.md` front matter:
        shelf_tags: [recommended, discuss]

      Backwards-compatible aliases also supported:
        recommended: true
        discuss: true
        talk: true
    {% endcomment %}

    {% assign recommended_books = collection | where_exp: "b", "b.shelf_tags contains 'recommended' or b.recommended == true or b.recommend == true" %}
    {% assign discuss_books = collection | where_exp: "b", "b.shelf_tags contains 'discuss' or b.shelf_tags contains 'discussion' or b.discuss == true or b.talk == true" %}
    {% assign art_books = collection | where_exp: "b", "b.shelf_tags contains 'art'" %}

    {% if recommended_books and recommended_books.size > 0 %}
      <h2 id="recommended">Books that live rent free in my head</h2>
      <p><em>pretty much the title</em></p>
      <div class="book-shelf-grid">
        {% for item in recommended_books reversed %}
          <figure class="cover">
            <a class="cover-link" href="{{ item.url | relative_url }}">
              {% if item.cover %}
                <img alt="{{ item.title }} cover" src="{{ item.cover | prepend: page.covers | relative_url }}" style="height:200px">
              {% elsif item.olid %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/olid/{{ item.olid }}-L.jpg?default=false" style="height:200px">
              {% elsif item.isbn %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/isbn/{{ item.isbn }}-L.jpg?default=false" style="height:200px">
              {% endif %}
            </a>
          </figure>
        {% endfor %}
      </div>
    {% endif %}

    {% if discuss_books and discuss_books.size > 0 %}
      <h2 id="discuss">Lmk if you've read these!</h2>
      <p><em>books that are still churning in my brain and would love your take on (a super set of rent-free books)</em></p>
      <div class="book-shelf-grid">
        {% for item in discuss_books reversed %}
          <figure class="cover">
            <a class="cover-link" href="{{ item.url | relative_url }}">
              {% if item.cover %}
                <img alt="{{ item.title }} cover" src="{{ item.cover | prepend: page.covers | relative_url }}" style="height:200px">
              {% elsif item.olid %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/olid/{{ item.olid }}-L.jpg?default=false" style="height:200px">
              {% elsif item.isbn %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/isbn/{{ item.isbn }}-L.jpg?default=false" style="height:200px">
              {% endif %}
            </a>
          </figure>
        {% endfor %}
      </div>
    {% endif %}

    {% if art_books and art_books.size > 0 %}
      <h2 id="art">Art</h2>
      <div class="book-shelf-grid">
        {% for item in art_books reversed %}
          <figure class="cover">
            <a class="cover-link" href="{{ item.url | relative_url }}">
              {% if item.cover %}
                <img alt="{{ item.title }} cover" src="{{ item.cover | prepend: page.covers | relative_url }}" style="height:200px">
              {% elsif item.olid %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/olid/{{ item.olid }}-L.jpg?default=false" style="height:200px">
              {% elsif item.isbn %}
                <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/isbn/{{ item.isbn }}-L.jpg?default=false" style="height:200px">
              {% endif %}
            </a>
          </figure>
        {% endfor %}
      </div>
    {% endif %}

    {% comment %} Collect all unique years from books not in recommended/discuss sections {% endcomment %}
    {% assign years_list = '' | split: ',' %}
    {% for item in collection %}
      {% assign is_recommended = false %}
      {% assign is_discuss = false %}
      {% assign is_art = false %}
      {% if item.shelf_tags contains 'recommended' or item.recommended == true or item.recommend == true %}
        {% assign is_recommended = true %}
      {% endif %}
      {% if item.shelf_tags contains 'discuss' or item.shelf_tags contains 'discussion' or item.discuss == true or item.talk == true %}
        {% assign is_discuss = true %}
      {% endif %}
      {% if item.shelf_tags contains 'art' %}
        {% assign is_art = true %}
      {% endif %}
      {% unless is_recommended or is_discuss or is_art %}
        {% if item.finished and item.finished != '' %}
          {% assign group_date = item.finished %}
        {% elsif item.started and item.started != '' %}
          {% assign group_date = item.started %}
        {% else %}
          {% assign group_date = item.date %}
        {% endif %}
        {% assign book_year = group_date | date: '%Y' %}
        {% if book_year and book_year != '' %}
          {% unless years_list contains book_year %}
            {% assign years_list = years_list | push: book_year %}
          {% endunless %}
        {% endif %}
      {% endunless %}
    {% endfor %}
    
    {% comment %} Sort years in descending order (newest first) {% endcomment %}
    {% assign sorted_years = years_list | sort | reverse %}
    
    {% comment %} Display books grouped by year, newest first {% endcomment %}
    {% for year in sorted_years %}
      {% assign has_books = false %}
      {% for item in collection reversed %}
        {% assign is_recommended = false %}
        {% assign is_discuss = false %}
        {% assign is_art = false %}
        {% if item.shelf_tags contains 'recommended' or item.recommended == true or item.recommend == true %}
          {% assign is_recommended = true %}
        {% endif %}
        {% if item.shelf_tags contains 'discuss' or item.shelf_tags contains 'discussion' or item.discuss == true or item.talk == true %}
          {% assign is_discuss = true %}
        {% endif %}
        {% if item.shelf_tags contains 'art' %}
          {% assign is_art = true %}
        {% endif %}
        {% unless is_recommended or is_discuss or is_art %}
          {% if item.finished and item.finished != '' %}
            {% assign group_date = item.finished %}
          {% elsif item.started and item.started != '' %}
            {% assign group_date = item.started %}
          {% else %}
            {% assign group_date = item.date %}
          {% endif %}
          {% assign item_year = group_date | date: '%Y' %}
          {% if item_year == year %}
            {% unless has_books %}
              <h1 id="y{{ year }}">
                <a href="{{ year | prepend: '/books/' | relative_url }}">{{ year }}</a>
              </h1>
              <ul>
              {% assign has_books = true %}
            {% endunless %}
            <figure class="cover">
              <a class="cover-link" href="{{ item.url | relative_url }}">
                {% if item.cover %}
                  <img alt="{{ item.title }} cover" src="{{ item.cover | prepend: page.covers | relative_url }}" style="height:200px">
                {% elsif item.olid %}
                  <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/olid/{{ item.olid }}-L.jpg?default=false" style="height:200px">
                {% elsif item.isbn %}
                  <img alt="{{ item.title }} cover" src="http://covers.openlibrary.org/b/isbn/{{ item.isbn }}-L.jpg?default=false" style="height:200px">
                {% endif %}
              </a>
            </figure>
          {% endif %}
        {% endunless %}
      {% endfor %}
      {% if has_books %}
        </ul>
      {% endif %}
    {% endfor %}
  {% endif %}
{% endif %}
