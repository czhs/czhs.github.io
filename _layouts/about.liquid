---
layout: default
---
{% comment %}
  Banners: render page.banners (a list of {id, text}). The legacy single
  announcement / announcement_id pair is still honored and shown first.
{% endcomment %}
{% if page.announcement or page.banners %}
  {% if page.announcement %}
  <div class="home-banner" data-id="{{ page.announcement_id }}" role="region" aria-label="Announcement" hidden>
    <span class="home-banner-text">{{ page.announcement }}</span>
    <button type="button" class="home-banner-close" aria-label="Dismiss announcement">&times;</button>
  </div>
  {% endif %}
  {% for b in page.banners %}
  <div class="home-banner" data-id="{{ b.id }}" role="region" aria-label="Announcement" hidden>
    <span class="home-banner-text">{{ b.text }}</span>
    <button type="button" class="home-banner-close" aria-label="Dismiss announcement">&times;</button>
  </div>
  {% endfor %}
  <style>
    .home-banner {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 0 0 2rem;
      padding: 0.7rem 0.75rem 0.7rem 1rem;
      border: 1px solid var(--global-divider-color);
      border-left: 3px solid var(--global-theme-color);
      border-radius: 8px;
      background: var(--global-card-bg-color);
      font-size: 0.92rem;
      line-height: 1.45;
    }
    .home-banner[hidden] { display: none; }
    .home-banner-text { flex: 1 1 auto; }
    .home-banner-text a { color: var(--global-theme-color); font-weight: 600; }
    .home-banner-close {
      flex: 0 0 auto;
      background: none;
      border: 0;
      font-size: 1.3rem;
      line-height: 1;
      color: var(--global-text-color);
      opacity: 0.45;
      cursor: pointer;
      padding: 0 0.3rem;
      transition: opacity 0.15s ease;
    }
    .home-banner-close:hover { opacity: 1; }
  </style>
  <script>
    (function () {
      var banners = document.querySelectorAll('.home-banner');
      Array.prototype.forEach.call(banners, function (el) {
        var key = 'home-banner:' + (el.dataset.id || 'default');
        try { if (localStorage.getItem(key) === '1') return; } catch (e) {}
        el.hidden = false;
        var btn = el.querySelector('.home-banner-close');
        if (btn) btn.addEventListener('click', function () {
          el.hidden = true;
          try { localStorage.setItem(key, '1'); } catch (e) {}
        });
      });
    })();
  </script>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
